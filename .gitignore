# ==============================================================
# WHITELIST: Ignore everything by default, only allow specific files.
# New files won't be tracked unless explicitly un-ignored below.
# ==============================================================

# ----------------------
# Ignore everything by default
# ----------------------
/*
!/.gitignore
!/.gitattributes
!/.editorconfig
!/.github/**
!/review.sh
!/.pre-commit-config.yaml
!/.commitlintrc.json
!/.lycheeignore
!/.github/
!/.github/**/*
!/scripts/
!/scripts/**
!/samples/
!/samples/**

# ----------------------
# Documentation
# ----------------------
!/LICENSE
!/*.md
!/docs/
!/docs/*

# ----------------------
# Source code
# ----------------------
!/src/
!/src/**/*

# ----------------------
# Tools
# ----------------------
!/tools/
!/tools/**/*

# ----------------------
# Build outputs (must stay ignored despite whitelist)
# ----------------------
bin/
obj/
*.dll
*.so
*.dylib
*.exe
*.pdb

# ----------------------
# IDE and editors
# ----------------------
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db

# ----------------------
# Release artifacts
# ----------------------
*.zip

# ----------------------
# Internal/handover docs (not part of the plugin distribution)
# ----------------------


# ----------------------
# Agentic workflows propagated shims
# ----------------------
propagated/

# ----------------------
# Python Ruff linter cache
# ----------------------


# ----------------------
# Mermaid diagram sources (regenerate from local mmdc tooling)
# ----------------------
docs/*.mmd

# ----------------------
# Sample .ithmb files — external downloads ignored; our synthetic samples tracked.
# ----------------------
/samples/*
!/samples/synthetic/
!/samples/synthetic/**
*.ithmb
!/samples/synthetic/*.ithmb
