# Whitelist convention: block everything by default, unblock specific paths.
# Prevents accidentally tracking stray files (build artifacts, IDE files, temp files).
/*
!/.gitignore
!/.gitattributes
!.editorconfig
!/LICENSE
!/rust-toolchain.toml
!/Cargo.toml
!/Cargo.lock
!/*.md
!/.github/
!/.github/**
!/.githooks/
!/.githooks/**
!/.opencode/
!/.opencode/**
!/docs/
!/docs/**
!/fuzz/
!/fuzz/**
!/tests/
!/tests/**
!/scripts/
!/scripts/**
!/crates/
!/crates/**
pymod/.venv/
pymod/__pycache__/

!/ithmb-core/
!/ithmb-core/**
!/pymod/
!/pymod/**
!/tools/
!/tools/**
!/samples/
!/samples/**

# Whitelist exceptions — re-exclude specific paths within whitelisted areas
target/
.omo/
tools/mcp-server/
mcp/
.ruff_cache/
*.bak
pymod/.pytest_cache/
