# Auto-detect text files and normalize line endings
* text=auto

# Rust source
*.rs text
*.toml text
*.lock text

# Documentation
*.md text diff=markdown
*.mmd text
*.svg text

# Config
*.json text
*.xml text

# Binaries (should never be tracked, but mark as binary if they slip through)
*.dll binary
*.so binary
*.dylib binary
*.exe binary
*.pdb binary
*.zip binary
